rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════
    match /users/{userId} {
      // Anyone authenticated can read any user profile
      allow read: if isSignedIn();

      // User can create their own document
      allow create: if isOwner(userId);

      // User can fully update their own document
      // OTHER users can update only friendRequests, friends, blockedUsers
      allow update: if isOwner(userId)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['friendRequests', 'friends', 'blockedUsers', 'oneSignalPlayerId']));

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════
    // CHATS COLLECTION
    // ═══════════════════════════════════════════════════════
    match /chats/{chatId} {
      // Any authenticated user can list chats — the Flutter query
      // already filters with where('participants', arrayContains: uid)
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read, write: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId))
             .data.participants;
      }
    }

    // ═══════════════════════════════════════════════════════
    // GROUPS COLLECTION
    // ═══════════════════════════════════════════════════════
    match /groups/{groupId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.members;

      allow create: if isSignedIn();

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members;

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.createdBy;

      match /messages/{messageId} {
        allow read, write: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/groups/$(groupId))
             .data.members;
      }
    }

    // ═══════════════════════════════════════════════════════
    // CALLS COLLECTION
    // ═══════════════════════════════════════════════════════
    match /calls/{callId} {
      // Any authenticated user can create a call
      allow create: if isSignedIn();

      // Participants can read the call
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.get('calleeId', '')
            || (resource.data.get('memberIds', [])
                .hasAny([request.auth.uid])));

      // Participants can update call status
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.get('calleeId', '')
            || (resource.data.get('memberIds', [])
                .hasAny([request.auth.uid])));

      // Only caller can delete
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.callerId;
    }
  }
}
